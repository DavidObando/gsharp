<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <PropertyGroup>
    <MSBuildAllProjects>$(MSBuildAllProjects);$(MSBuildThisFileFullPath)</MSBuildAllProjects>
    <Language Condition="'$(Language)' == ''">GSharp</Language>
    <TargetRuntime Condition="'$(TargetRuntime)' == ''">Managed</TargetRuntime>
    <DefaultProjectTypeGuid Condition="'$(DefaultProjectTypeGuid)' == ''">{F1526B4D-C1A8-4B42-B2F7-48DA6F9CA033}</DefaultProjectTypeGuid>
    <DefineCommonItemSchemas Condition="'$(DefineCommonItemSchemas)' == ''">true</DefineCommonItemSchemas>
    <DefineCommonReferenceSchemas Condition="'$(DefineCommonReferenceSchemas)' == ''">true</DefineCommonReferenceSchemas>
    <DefineCommonCapabilities Condition="'$(DefineCommonCapabilities)' == ''">true</DefineCommonCapabilities>
    <GsharpDesignTimeTargetsPath Condition="'$(GsharpDesignTimeTargetsPath)' == ''">$(MSBuildExtensionsPath)\Microsoft\VisualStudio\Managed\Microsoft.Managed.DesignTime.targets</GsharpDesignTimeTargetsPath>
  </PropertyGroup>

  <!-- Managed design-time targets must precede Microsoft.NET.Sdk's NuGet
       targets so the SDK can override their compatibility fallbacks. -->
  <Import Project="$(GsharpDesignTimeTargetsPath)"
          Condition="'$(BuildingInsideVisualStudio)' == 'true' and Exists('$(GsharpDesignTimeTargetsPath)')" />

  <Import Project="Sdk.targets" Sdk="Microsoft.NET.Sdk" />

  <ItemGroup Condition="'$(BuildingInsideVisualStudio)' == 'true'">
    <ProjectCapability Include="GSharp" />
    <ProjectCapability Include="CPS" />
    <ProjectCapability Include="Managed" />
    <ProjectCapability Include="ProjectPropertyInterception" />
    <ProjectCapability Include="UseFileGlobs" />
    <ProjectCapability Include="OpenProjectFile" />
    <ProjectCapability Include="AssemblyReferences" />
    <ProjectCapability Include="ProjectReferences" />
    <ProjectCapability Include="PackageReferences" />
    <ProjectCapability Include="DependenciesTree" />
    <ProjectCapability Include="LaunchProfiles" />
  </ItemGroup>

</Project>
