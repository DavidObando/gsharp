<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- Inherits the entire Microsoft.NET.Sdk pipeline and only swaps CoreCompile
       so that .gs sources are compiled by gsc instead of csc. -->

  <Import Project="$(MSBuildThisFileDirectory)Gsharp.NET.Core.Sdk.targets" />

  <Import Project="$(MSBuildToolsPath)\Microsoft.Common.targets" />

</Project>
