<?xml version="1.0" encoding="utf-8"?>
<Rule Name="CollectedPackageReference"
      PageTemplate="generic"
      xmlns="http://schemas.microsoft.com/build/2009/properties">
  <Rule.DataSource>
    <DataSource HasConfigurationCondition="False"
                ItemType="PackageReference"
                Persistence="ProjectFile"
                SourceOfDefaultValue="AfterContext"
                SourceType="Evaluation" />
  </Rule.DataSource>

  <StringListProperty Name="Aliases" ReadOnly="True" Visible="False" />
  <StringProperty Name="ExcludeAssets" ReadOnly="True" Visible="False" />
  <BoolProperty Name="GeneratePathProperty" ReadOnly="True" Visible="False" />
  <StringProperty Name="IncludeAssets" ReadOnly="True" Visible="False" />
  <StringProperty Name="IsImplicitlyDefined" ReadOnly="True" Visible="False" />
  <StringProperty Name="Name" ReadOnly="True" Visible="False">
    <StringProperty.DataSource>
      <DataSource PersistedName="{}{Identity}" SourceOfDefaultValue="AfterContext" />
    </StringProperty.DataSource>
  </StringProperty>
  <StringProperty Name="NoWarn" ReadOnly="True" Visible="False" />
  <StringProperty Name="PrivateAssets" ReadOnly="True" Visible="False" />
  <StringProperty Name="Version" ReadOnly="True" Visible="False" />
  <StringProperty Name="VersionOverride" ReadOnly="True" Visible="False" />
  <BoolProperty Name="Visible" ReadOnly="True" Visible="False" />
</Rule>
