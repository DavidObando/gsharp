<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <UsingTask AssemblyFile="$(GsharpToolFullPath)" TaskName="Gsharp.NET.Sdk.Tools.BuildTask" />

  <PropertyGroup>
    <CoreCompileDependsOn>_ComputeNonExistentFileProperty</CoreCompileDependsOn>
  </PropertyGroup>

  <!-- Locate and add mscorlib unless NoStdLib. Mirrors peachpie's Core.Sdk.targets. -->
  <ItemGroup Condition=" '$(NoStdLib)' != 'true' ">
    <_ExplicitReference Include="$(FrameworkPathOverride)\mscorlib.dll" Condition=" '$(FrameworkPathOverride)' != '' " />
  </ItemGroup>

  <Target Name="CoreCompile"
          Inputs="$(MSBuildAllProjects);@(Compile);@(ReferencePath)"
          Outputs="@(IntermediateAssembly)"
          DependsOnTargets="$(CoreCompileDependsOn)">

    <!-- When the SDK asks for a reference assembly (ProduceReferenceAssembly=true),
         Microsoft.Common.Targets sets @(IntermediateRefAssembly) to obj/refint/{name}.dll.
         Forward that path to gsc via /refout: so the metadata-only sibling is written
         in the same pass as the runtime assembly. -->
    <PropertyGroup>
      <_GsharpRefAssemblyPath Condition=" '$(ProduceReferenceAssembly)' == 'true' ">@(IntermediateRefAssembly)</_GsharpRefAssemblyPath>
    </PropertyGroup>

    <BuildTask
        GsharpCompilerFullPath="$(GsharpCompilerFullPath)"
        OutputPath="$(IntermediateOutputPath)"
        OutputName="$(TargetName)"
        TempOutputPath="$(IntermediateOutputPath)"
        TargetFramework="$(TargetFramework)"
        BasePath="$(MSBuildProjectDirectory)"
        Optimization="$(Optimize)"
        DebugType="$(DebugType)"
        PdbFile="@(_DebugSymbolsIntermediatePath)"
        Version="$(Version)"
        OutputType="$(OutputType)"
        RefAssembly="$(_GsharpRefAssemblyPath)"
        NoWarn="$(NoWarn)"
        TreatWarningsAsErrors="$(TreatWarningsAsErrors)"
        WarningsAsErrors="$(WarningsAsErrors)"
        Compile="@(Compile)"
        References="@(ReferencePath)"
        ResponseFilePath="$(IntermediateOutputPath)$(TargetName).rsp" />

    <ItemGroup>
      <FileWrites Include="$(IntermediateOutputPath)$(TargetName)$(TargetExt)" />
      <FileWrites Include="$(_GsharpRefAssemblyPath)" Condition=" '$(_GsharpRefAssemblyPath)' != '' " />
    </ItemGroup>
  </Target>

  <!-- The CreateManifestResourceNames target is required by Common.targets; defer to C# semantics. -->
  <Target Name="CreateManifestResourceNames" />

</Project>
