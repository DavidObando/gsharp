{
    "$schema": "http://json.schemastore.org/template",
    "author": "GSharp Authors",
    "classifications": [ "Web", "GSharp" ],
    "identity": "GSharp.Templates.Web",
    "name": "GSharp Web Application",
    "shortName": "gsharp-web",
    "description": "A minimal GSharp web application that serves HTTP requests using the BCL HttpListener and builds with Gsharp.NET.Sdk.",
    "tags": {
        "language": "GSharp",
        "type": "project"
    },
    "sourceName": "GsharpWebApp",
    "preferNameDirectory": true,
    "symbols": {
        "Framework": {
            "type": "parameter",
            "datatype": "choice",
            "choices": [
                { "choice": "net10.0", "description": "Target .NET 10.0" }
            ],
            "defaultValue": "net10.0",
            "replaces": "net10.0"
        }
    }
}
