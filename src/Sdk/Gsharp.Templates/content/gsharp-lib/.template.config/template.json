{
    "$schema": "http://json.schemastore.org/template",
    "author": "GSharp Authors",
    "classifications": [ "Library", "GSharp" ],
    "identity": "GSharp.Templates.Library",
    "name": "GSharp Class Library",
    "shortName": "gsharp-lib",
    "description": "A GSharp class library that builds with Gsharp.NET.Sdk and can be packed as a NuGet for consumption from C#, F#, or other GSharp projects.",
    "tags": {
        "language": "GSharp",
        "type": "project"
    },
    "sourceName": "GsharpLibrary",
    "preferNameDirectory": true,
    "symbols": {
        "Framework": {
            "type": "parameter",
            "datatype": "choice",
            "choices": [
                { "choice": "net10.0", "description": "Target .NET 10.0" }
            ],
            "defaultValue": "net10.0",
            "replaces": "net10.0"
        }
    }
}
