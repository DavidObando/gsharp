<?xml version="1.0" encoding="utf-8"?>
<!--
  Adds a local "./packages" folder as a NuGet source so a side-loaded copy of
  Gsharp.NET.Sdk (and any other GSharp packages) is discoverable by `dotnet build`.
  Drop the matching Gsharp.NET.Sdk.<version>.nupkg into ./packages/, or remove
  this file once GSharp packages are published to a public NuGet feed.
-->
<configuration>
  <packageSources>
    <add key="gsharp-local" value="./packages" />
  </packageSources>
</configuration>
