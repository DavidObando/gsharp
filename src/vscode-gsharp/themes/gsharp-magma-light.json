{
  "name": "GSharp Magma Light",
  "type": "light",
  "colors": {
    "editor.background": "#FFF7F2",
    "editor.foreground": "#2B1010",
    "editorLineNumber.foreground": "#BD9385",
    "editorLineNumber.activeForeground": "#C0392B",
    "editorCursor.foreground": "#C0392B",
    "editor.selectionBackground": "#FFCDBA",
    "editor.inactiveSelectionBackground": "#F3DDD2",
    "editor.lineHighlightBackground": "#FBEBE3",
    "editorIndentGuide.background1": "#EDD6CB",
    "editorIndentGuide.activeBackground1": "#CC9A87",
    "editorBracketMatch.background": "#FFCDBA",
    "editorBracketMatch.border": "#C0392B",
    "titleBar.activeBackground": "#FBE7DD",
    "titleBar.activeForeground": "#2B1010",
    "activityBar.background": "#FBE7DD",
    "activityBar.foreground": "#C0392B",
    "activityBarBadge.background": "#C0392B",
    "activityBarBadge.foreground": "#FFF3EC",
    "sideBar.background": "#FBEDE5",
    "sideBar.foreground": "#4A2A20",
    "sideBar.border": "#EDD6CB",
    "sideBarTitle.foreground": "#C0392B",
    "sideBarSectionHeader.background": "#F3DDD2",
    "sideBarSectionHeader.foreground": "#9A3412",
    "list.hoverBackground": "#F5E0D6",
    "list.inactiveSelectionBackground": "#F3DDD2",
    "list.focusBackground": "#FFCDBA",
    "list.highlightForeground": "#C0392B",
    "tree.indentGuidesStroke": "#CC9A87",
    "statusBar.background": "#C0392B",
    "statusBar.foreground": "#FFF3EC",
    "statusBar.noFolderBackground": "#8A2820",
    "editorGroupHeader.tabsBackground": "#FBEDE5",
    "editorGroupHeader.tabsBorder": "#EDD6CB",
    "editorGroupHeader.noTabsBackground": "#FBEDE5",
    "tab.activeBorderTop": "#C0392B",
    "tab.activeBackground": "#FFF7F2",
    "tab.inactiveBackground": "#FBEDE5",
    "tab.activeForeground": "#2B1010",
    "tab.inactiveForeground": "#9C5A3C",
    "tab.border": "#EDD6CB",
    "focusBorder": "#C0392B",
    "list.activeSelectionBackground": "#FFCDBA",
    "button.background": "#C0392B",
    "button.foreground": "#FFF3EC"
  },
  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#9C5A3C", "fontStyle": "italic" } },
    { "scope": "keyword", "settings": { "foreground": "#C0392B" } },
    { "scope": "keyword.control", "settings": { "foreground": "#7B2CBF" } },
    { "scope": "keyword.control.async", "settings": { "foreground": "#7B2CBF" } },
    { "scope": "keyword.declaration", "settings": { "foreground": "#C0392B" } },
    { "scope": "keyword.modifier", "settings": { "foreground": "#C0392B" } },
    { "scope": "string", "settings": { "foreground": "#9A3412" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#1B7D3F" } },
    { "scope": "constant.language", "settings": { "foreground": "#B11226" } },
    { "scope": "support.type.primitive", "settings": { "foreground": "#0E7490" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#9A6A00" } },
    { "scope": "entity.name.type", "settings": { "foreground": "#0E7490" } },
    { "scope": "variable", "settings": { "foreground": "#7A2E12" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#5A2018" } },
    { "scope": "punctuation", "settings": { "foreground": "#5A2018" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "type": "#0E7490",
    "interface": "#0E7490",
    "struct": "#0E7490",
    "enum": "#0E7490",
    "enumMember": "#B11226",
    "namespace": "#5A2018",
    "function": "#9A6A00",
    "method": "#9A6A00",
    "parameter": "#7A2E12",
    "variable": "#7A2E12",
    "property": "#7A2E12",
    "keyword": "#C0392B",
    "string": "#9A3412",
    "number": "#1B7D3F",
    "operator": "#5A2018",
    "comment": "#9C5A3C"
  }
}
