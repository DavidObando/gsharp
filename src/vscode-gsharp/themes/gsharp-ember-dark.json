{
  "name": "GSharp Ember Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#181210",
    "editor.foreground": "#F3E9DF",
    "editorLineNumber.foreground": "#6E5A4C",
    "editorLineNumber.activeForeground": "#FFB347",
    "editorCursor.foreground": "#FFB347",
    "editor.selectionBackground": "#5A2A1E",
    "editor.inactiveSelectionBackground": "#3A201A",
    "editor.lineHighlightBackground": "#201813",
    "editorIndentGuide.background1": "#2C211B",
    "editorIndentGuide.activeBackground1": "#5A3A22",
    "editorWhitespace.foreground": "#3A2C24",
    "editorBracketMatch.background": "#5A2A1E",
    "editorBracketMatch.border": "#FFC24B",
    "titleBar.activeBackground": "#201712",
    "titleBar.activeForeground": "#F3E9DF",
    "activityBar.background": "#1F1611",
    "activityBar.foreground": "#FFC24B",
    "activityBarBadge.background": "#C0392B",
    "activityBarBadge.foreground": "#FFF3E6",
    "sideBar.background": "#1F1611",
    "sideBar.foreground": "#D8C8B8",
    "sideBar.border": "#2C211B",
    "sideBarTitle.foreground": "#FFB347",
    "sideBarSectionHeader.background": "#2A1E17",
    "sideBarSectionHeader.foreground": "#FFC24B",
    "list.hoverBackground": "#2C211B",
    "list.inactiveSelectionBackground": "#3A201A",
    "list.focusBackground": "#5A2A1E",
    "list.highlightForeground": "#FFC24B",
    "tree.indentGuidesStroke": "#5A3A22",
    "statusBar.background": "#C0392B",
    "statusBar.foreground": "#FFF3E6",
    "statusBar.noFolderBackground": "#8A2820",
    "editorGroupHeader.tabsBackground": "#1F1611",
    "editorGroupHeader.tabsBorder": "#2C211B",
    "editorGroupHeader.noTabsBackground": "#1F1611",
    "tab.activeBorderTop": "#FFB347",
    "tab.activeBackground": "#181210",
    "tab.inactiveBackground": "#1F1611",
    "tab.activeForeground": "#F3E9DF",
    "tab.inactiveForeground": "#9A8366",
    "tab.border": "#2C211B",
    "focusBorder": "#FFB347",
    "list.activeSelectionBackground": "#5A2A1E",
    "button.background": "#C0392B",
    "button.foreground": "#FFF3E6"
  },
  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#9A8366", "fontStyle": "italic" } },
    { "scope": "keyword", "settings": { "foreground": "#FFC24B" } },
    { "scope": "keyword.control", "settings": { "foreground": "#FF67C2" } },
    { "scope": "keyword.control.async", "settings": { "foreground": "#FF67C2" } },
    { "scope": "keyword.declaration", "settings": { "foreground": "#FFC24B" } },
    { "scope": "keyword.modifier", "settings": { "foreground": "#FFC24B" } },
    { "scope": "string", "settings": { "foreground": "#FF8A5B" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#B6FF7A" } },
    { "scope": "constant.language", "settings": { "foreground": "#FF5E5B" } },
    { "scope": "support.type.primitive", "settings": { "foreground": "#2EE6C8" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#FFD93D" } },
    { "scope": "entity.name.type", "settings": { "foreground": "#2EE6C8" } },
    { "scope": "variable", "settings": { "foreground": "#7FD7FF" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#E8C9A0" } },
    { "scope": "punctuation", "settings": { "foreground": "#E8C9A0" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "type": "#2EE6C8",
    "interface": "#5EEAD4",
    "struct": "#2EE6C8",
    "enum": "#5EEAD4",
    "enumMember": "#FF5E5B",
    "namespace": "#E8C9A0",
    "function": "#FFD93D",
    "method": "#FFD93D",
    "parameter": "#7FD7FF",
    "variable": "#7FD7FF",
    "property": "#9CDCFE",
    "keyword": "#FFC24B",
    "string": "#FF8A5B",
    "number": "#B6FF7A",
    "operator": "#E8C9A0",
    "comment": "#9A8366"
  }
}
