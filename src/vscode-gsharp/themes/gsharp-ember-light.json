{
  "name": "GSharp Ember Light",
  "type": "light",
  "colors": {
    "editor.background": "#FFFBF5",
    "editor.foreground": "#2A1A12",
    "editorLineNumber.foreground": "#B79E86",
    "editorLineNumber.activeForeground": "#C0392B",
    "editorCursor.foreground": "#C0392B",
    "editor.selectionBackground": "#FFD9A8",
    "editor.inactiveSelectionBackground": "#F3E3CE",
    "editor.lineHighlightBackground": "#FBF1E4",
    "editorIndentGuide.background1": "#EBDCC8",
    "editorIndentGuide.activeBackground1": "#C9A77E",
    "editorBracketMatch.background": "#FFD9A8",
    "editorBracketMatch.border": "#C0392B",
    "titleBar.activeBackground": "#FBEFE0",
    "titleBar.activeForeground": "#2A1A12",
    "activityBar.background": "#FBEFE0",
    "activityBar.foreground": "#C0392B",
    "activityBarBadge.background": "#C0392B",
    "activityBarBadge.foreground": "#FFF3E6",
    "sideBar.background": "#FBF3E8",
    "sideBar.foreground": "#4A3525",
    "sideBar.border": "#EBDCC8",
    "sideBarTitle.foreground": "#C0392B",
    "sideBarSectionHeader.background": "#F3E3CE",
    "sideBarSectionHeader.foreground": "#8A4A1A",
    "list.hoverBackground": "#F3E8D8",
    "list.inactiveSelectionBackground": "#F3E3CE",
    "list.focusBackground": "#FFD9A8",
    "list.highlightForeground": "#C0392B",
    "tree.indentGuidesStroke": "#C9A77E",
    "statusBar.background": "#C0392B",
    "statusBar.foreground": "#FFF3E6",
    "statusBar.noFolderBackground": "#8A2820",
    "editorGroupHeader.tabsBackground": "#FBF3E8",
    "editorGroupHeader.tabsBorder": "#EBDCC8",
    "editorGroupHeader.noTabsBackground": "#FBF3E8",
    "tab.activeBorderTop": "#C0392B",
    "tab.activeBackground": "#FFFBF5",
    "tab.inactiveBackground": "#FBF3E8",
    "tab.activeForeground": "#2A1A12",
    "tab.inactiveForeground": "#8A6D3B",
    "tab.border": "#EBDCC8",
    "focusBorder": "#C0392B",
    "list.activeSelectionBackground": "#FFD9A8",
    "button.background": "#C0392B",
    "button.foreground": "#FFF3E6"
  },
  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#8A6D3B", "fontStyle": "italic" } },
    { "scope": "keyword", "settings": { "foreground": "#B11226" } },
    { "scope": "keyword.control", "settings": { "foreground": "#8A1F9E" } },
    { "scope": "keyword.control.async", "settings": { "foreground": "#8A1F9E" } },
    { "scope": "keyword.declaration", "settings": { "foreground": "#B11226" } },
    { "scope": "keyword.modifier", "settings": { "foreground": "#B11226" } },
    { "scope": "string", "settings": { "foreground": "#A33214" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#3E7C12" } },
    { "scope": "constant.language", "settings": { "foreground": "#C0392B" } },
    { "scope": "support.type.primitive", "settings": { "foreground": "#0E7C86" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#A85A00" } },
    { "scope": "entity.name.type", "settings": { "foreground": "#0E7C86" } },
    { "scope": "variable", "settings": { "foreground": "#1B3FA0" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#5A3A22" } },
    { "scope": "punctuation", "settings": { "foreground": "#5A3A22" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "type": "#0E7C86",
    "interface": "#0E7C86",
    "struct": "#0E7C86",
    "enum": "#0E7C86",
    "enumMember": "#C0392B",
    "namespace": "#5A3A22",
    "function": "#A85A00",
    "method": "#A85A00",
    "parameter": "#1B3FA0",
    "variable": "#1B3FA0",
    "property": "#1B3FA0",
    "keyword": "#B11226",
    "string": "#A33214",
    "number": "#3E7C12",
    "operator": "#5A3A22",
    "comment": "#8A6D3B"
  }
}
