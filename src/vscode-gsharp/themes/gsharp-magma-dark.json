{
  "name": "GSharp Magma Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#140C0C",
    "editor.foreground": "#FFE8D6",
    "editorLineNumber.foreground": "#6B4A40",
    "editorLineNumber.activeForeground": "#FF4D3D",
    "editorCursor.foreground": "#FF4D3D",
    "editor.selectionBackground": "#5A1A14",
    "editor.inactiveSelectionBackground": "#3A1410",
    "editor.lineHighlightBackground": "#1E1010",
    "editorIndentGuide.background1": "#2A1614",
    "editorIndentGuide.activeBackground1": "#5A211A",
    "editorWhitespace.foreground": "#3A201C",
    "editorBracketMatch.background": "#5A1A14",
    "editorBracketMatch.border": "#FF4D3D",
    "titleBar.activeBackground": "#1C0F0E",
    "titleBar.activeForeground": "#FFE8D6",
    "activityBar.background": "#1C0F0E",
    "activityBar.foreground": "#FF4D3D",
    "activityBarBadge.background": "#FF4D3D",
    "activityBarBadge.foreground": "#1A0A08",
    "sideBar.background": "#1C0F0E",
    "sideBar.foreground": "#E8C8B8",
    "sideBar.border": "#2A1614",
    "sideBarTitle.foreground": "#FF4D3D",
    "sideBarSectionHeader.background": "#281412",
    "sideBarSectionHeader.foreground": "#FF6B5B",
    "list.hoverBackground": "#2A1614",
    "list.inactiveSelectionBackground": "#3A1410",
    "list.focusBackground": "#5A1A14",
    "list.highlightForeground": "#FF4D3D",
    "tree.indentGuidesStroke": "#5A211A",
    "statusBar.background": "#8A2018",
    "statusBar.foreground": "#FFE8D6",
    "statusBar.noFolderBackground": "#5A130E",
    "editorGroupHeader.tabsBackground": "#1C0F0E",
    "editorGroupHeader.tabsBorder": "#2A1614",
    "editorGroupHeader.noTabsBackground": "#1C0F0E",
    "tab.activeBorderTop": "#FF4D3D",
    "tab.activeBackground": "#140C0C",
    "tab.inactiveBackground": "#1C0F0E",
    "tab.activeForeground": "#FFE8D6",
    "tab.inactiveForeground": "#7E5E52",
    "tab.border": "#2A1614",
    "focusBorder": "#FF4D3D",
    "list.activeSelectionBackground": "#5A1A14",
    "button.background": "#FF4D3D",
    "button.foreground": "#1A0A08"
  },
  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#7E5E52", "fontStyle": "italic" } },
    { "scope": "keyword", "settings": { "foreground": "#FF4D3D" } },
    { "scope": "keyword.control", "settings": { "foreground": "#C77DFF" } },
    { "scope": "keyword.control.async", "settings": { "foreground": "#C77DFF" } },
    { "scope": "keyword.declaration", "settings": { "foreground": "#FF4D3D" } },
    { "scope": "keyword.modifier", "settings": { "foreground": "#FF4D3D" } },
    { "scope": "string", "settings": { "foreground": "#FFA630" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#39FF88" } },
    { "scope": "constant.language", "settings": { "foreground": "#FF2E63" } },
    { "scope": "support.type.primitive", "settings": { "foreground": "#22D3EE" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#FFE45E" } },
    { "scope": "entity.name.type", "settings": { "foreground": "#22D3EE" } },
    { "scope": "variable", "settings": { "foreground": "#FFB37A" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#FFD0B0" } },
    { "scope": "punctuation", "settings": { "foreground": "#FFD0B0" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "type": "#22D3EE",
    "interface": "#67E8F9",
    "struct": "#22D3EE",
    "enum": "#67E8F9",
    "enumMember": "#FF2E63",
    "namespace": "#FFD0B0",
    "function": "#FFE45E",
    "method": "#FFE45E",
    "parameter": "#FFB37A",
    "variable": "#FFB37A",
    "property": "#FFCBA0",
    "keyword": "#FF4D3D",
    "string": "#FFA630",
    "number": "#39FF88",
    "operator": "#FFD0B0",
    "comment": "#7E5E52"
  }
}
