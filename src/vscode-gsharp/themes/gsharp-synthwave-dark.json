{
  "name": "GSharp Synthwave Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#1B1320",
    "editor.foreground": "#F5E6D8",
    "editorLineNumber.foreground": "#6A5A78",
    "editorLineNumber.activeForeground": "#FF5DA2",
    "editorCursor.foreground": "#FF5DA2",
    "editor.selectionBackground": "#43234A",
    "editor.inactiveSelectionBackground": "#2E1A36",
    "editor.lineHighlightBackground": "#241A2C",
    "editorIndentGuide.background1": "#2F2238",
    "editorIndentGuide.activeBackground1": "#5A3A6E",
    "editorWhitespace.foreground": "#352A40",
    "editorBracketMatch.background": "#43234A",
    "editorBracketMatch.border": "#FF5DA2",
    "titleBar.activeBackground": "#221830",
    "titleBar.activeForeground": "#F5E6D8",
    "activityBar.background": "#221830",
    "activityBar.foreground": "#FFC24B",
    "activityBarBadge.background": "#FF5DA2",
    "activityBarBadge.foreground": "#1B1320",
    "sideBar.background": "#221830",
    "sideBar.foreground": "#D8C8E0",
    "sideBar.border": "#2F2238",
    "sideBarTitle.foreground": "#FF5DA2",
    "sideBarSectionHeader.background": "#2E1F3A",
    "sideBarSectionHeader.foreground": "#FFC24B",
    "list.hoverBackground": "#2F2238",
    "list.inactiveSelectionBackground": "#2E1A36",
    "list.focusBackground": "#43234A",
    "list.highlightForeground": "#FF5DA2",
    "tree.indentGuidesStroke": "#5A3A6E",
    "statusBar.background": "#7209B7",
    "statusBar.foreground": "#F5E6D8",
    "statusBar.noFolderBackground": "#4A0780",
    "editorGroupHeader.tabsBackground": "#221830",
    "editorGroupHeader.tabsBorder": "#2F2238",
    "editorGroupHeader.noTabsBackground": "#221830",
    "tab.activeBorderTop": "#FF5DA2",
    "tab.activeBackground": "#1B1320",
    "tab.inactiveBackground": "#221830",
    "tab.activeForeground": "#F5E6D8",
    "tab.inactiveForeground": "#8A6E8C",
    "tab.border": "#2F2238",
    "focusBorder": "#FF5DA2",
    "list.activeSelectionBackground": "#43234A",
    "button.background": "#FF5DA2",
    "button.foreground": "#1B1320"
  },
  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#8A6E8C", "fontStyle": "italic" } },
    { "scope": "keyword", "settings": { "foreground": "#FFC24B" } },
    { "scope": "keyword.control", "settings": { "foreground": "#FF5DA2" } },
    { "scope": "keyword.control.async", "settings": { "foreground": "#FF5DA2" } },
    { "scope": "keyword.declaration", "settings": { "foreground": "#FFC24B" } },
    { "scope": "keyword.modifier", "settings": { "foreground": "#FFC24B" } },
    { "scope": "string", "settings": { "foreground": "#FF9E64" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#9DFF6B" } },
    { "scope": "constant.language", "settings": { "foreground": "#FF4D6D" } },
    { "scope": "support.type.primitive", "settings": { "foreground": "#5EEAD4" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#FFD93D" } },
    { "scope": "entity.name.type", "settings": { "foreground": "#5EEAD4" } },
    { "scope": "variable", "settings": { "foreground": "#8AB4FF" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#E6C8E0" } },
    { "scope": "punctuation", "settings": { "foreground": "#E6C8E0" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "type": "#5EEAD4",
    "interface": "#99F6E4",
    "struct": "#5EEAD4",
    "enum": "#99F6E4",
    "enumMember": "#FF4D6D",
    "namespace": "#E6C8E0",
    "function": "#FFD93D",
    "method": "#FFD93D",
    "parameter": "#8AB4FF",
    "variable": "#8AB4FF",
    "property": "#B5CCFF",
    "keyword": "#FFC24B",
    "string": "#FF9E64",
    "number": "#9DFF6B",
    "operator": "#E6C8E0",
    "comment": "#8A6E8C"
  }
}
