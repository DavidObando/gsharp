{
  "name": "GSharp Synthwave Light",
  "type": "light",
  "colors": {
    "editor.background": "#FFFAF6",
    "editor.foreground": "#2A1730",
    "editorLineNumber.foreground": "#B59ABF",
    "editorLineNumber.activeForeground": "#B5179E",
    "editorCursor.foreground": "#B5179E",
    "editor.selectionBackground": "#F3CFE8",
    "editor.inactiveSelectionBackground": "#EBDDF0",
    "editor.lineHighlightBackground": "#FAF0F6",
    "editorIndentGuide.background1": "#E8D8EC",
    "editorIndentGuide.activeBackground1": "#C79ACE",
    "editorBracketMatch.background": "#F3CFE8",
    "editorBracketMatch.border": "#B5179E",
    "titleBar.activeBackground": "#FAEFF6",
    "titleBar.activeForeground": "#2A1730",
    "activityBar.background": "#FAEFF6",
    "activityBar.foreground": "#B5179E",
    "activityBarBadge.background": "#7209B7",
    "activityBarBadge.foreground": "#FFF3FB",
    "sideBar.background": "#FAF0F8",
    "sideBar.foreground": "#4A2A52",
    "sideBar.border": "#E8D8EC",
    "sideBarTitle.foreground": "#B5179E",
    "sideBarSectionHeader.background": "#EBDDF0",
    "sideBarSectionHeader.foreground": "#7209B7",
    "list.hoverBackground": "#F3E5F3",
    "list.inactiveSelectionBackground": "#EBDDF0",
    "list.focusBackground": "#F3CFE8",
    "list.highlightForeground": "#B5179E",
    "tree.indentGuidesStroke": "#C79ACE",
    "statusBar.background": "#7209B7",
    "statusBar.foreground": "#FFF3FB",
    "statusBar.noFolderBackground": "#4A0780",
    "editorGroupHeader.tabsBackground": "#FAF0F8",
    "editorGroupHeader.tabsBorder": "#E8D8EC",
    "editorGroupHeader.noTabsBackground": "#FAF0F8",
    "tab.activeBorderTop": "#B5179E",
    "tab.activeBackground": "#FFFAF6",
    "tab.inactiveBackground": "#FAF0F8",
    "tab.activeForeground": "#2A1730",
    "tab.inactiveForeground": "#86609A",
    "tab.border": "#E8D8EC",
    "focusBorder": "#B5179E",
    "list.activeSelectionBackground": "#F3CFE8",
    "button.background": "#7209B7",
    "button.foreground": "#FFF3FB"
  },
  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#86609A", "fontStyle": "italic" } },
    { "scope": "keyword", "settings": { "foreground": "#B5179E" } },
    { "scope": "keyword.control", "settings": { "foreground": "#7209B7" } },
    { "scope": "keyword.control.async", "settings": { "foreground": "#7209B7" } },
    { "scope": "keyword.declaration", "settings": { "foreground": "#B5179E" } },
    { "scope": "keyword.modifier", "settings": { "foreground": "#B5179E" } },
    { "scope": "string", "settings": { "foreground": "#A4133C" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#2D6A4F" } },
    { "scope": "constant.language", "settings": { "foreground": "#C0392B" } },
    { "scope": "support.type.primitive", "settings": { "foreground": "#0E7C86" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#BC6C00" } },
    { "scope": "entity.name.type", "settings": { "foreground": "#0E7C86" } },
    { "scope": "variable", "settings": { "foreground": "#3A0CA3" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#4A2A52" } },
    { "scope": "punctuation", "settings": { "foreground": "#4A2A52" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "type": "#0E7C86",
    "interface": "#0E7C86",
    "struct": "#0E7C86",
    "enum": "#0E7C86",
    "enumMember": "#C0392B",
    "namespace": "#4A2A52",
    "function": "#BC6C00",
    "method": "#BC6C00",
    "parameter": "#3A0CA3",
    "variable": "#3A0CA3",
    "property": "#3A0CA3",
    "keyword": "#B5179E",
    "string": "#A4133C",
    "number": "#2D6A4F",
    "operator": "#4A2A52",
    "comment": "#86609A"
  }
}
