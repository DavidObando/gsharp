<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <packageSources>
        <clear />
        <add key="NuGet official package source" value="https://api.nuget.org/v3/index.json" />
        <!-- Local folder for the Gsharp.Microsoft.CodeAnalysis NuGet built from src/Roslyn/. -->
        <!-- Run: cd src/Roslyn && ./GsharpNuget.sh to produce the package, then it will be -->
        <!-- discoverable here under .nugs/. -->
        <add key="Gsharp local packages" value=".nugs" />
    </packageSources>
    <disabledPackageSources>
        <clear />
    </disabledPackageSources>
</configuration>

