<Project Sdk="Gsharp.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>SourceGen</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- A real NuGet Roslyn source generator. The Gsharp.NET.Sdk resolves its
         C# analyzer assets (ADR-0145 §E) and runs it via gsgen before gsc. -->
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
  </ItemGroup>

</Project>
