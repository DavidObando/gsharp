{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": ["--extensionDevelopmentPath=${workspaceFolder}/src/vscode-gsharp"],
            "outFiles": ["${workspaceFolder}/src/vscode-gsharp/dist/**/*.js"],
            "preLaunchTask": "npm: compile - src/vscode-gsharp"
        }
    ]
}